+
+/* ── Guided Tour ── */
+
+.tour-overlay {
+  position: fixed;
+  inset: 0;
+  z-index: 2500;
+  background: rgba(0, 0, 0, 0.45);
+  transition: clip-path 0.3s ease;
+  pointer-events: auto;
+}
+
+.tour-backdrop {
+  position: fixed;
+  inset: 0;
+  z-index: 2500;
+  background: rgba(0, 0, 0, 0.55);
+}
+
+.tour-glow-ring {
+  position: fixed;
+  z-index: 2501;
+  border: 1.5px solid rgba(var(--accent-active-rgb), 0.6);
+  box-shadow:
+    0 0 0 2px rgba(var(--accent-active-rgb), 0.15),
+    0 0 20px rgba(var(--accent-active-rgb), 0.25);
+  pointer-events: none;
+  transition: top 0.3s ease, left 0.3s ease, width 0.3s ease, height 0.3s ease;
+  animation: tour-glow-pulse 2s ease-in-out infinite;
+}
+
+@keyframes tour-glow-pulse {
+  0%, 100% {
+    box-shadow:
+      0 0 0 2px rgba(var(--accent-active-rgb), 0.15),
+      0 0 20px rgba(var(--accent-active-rgb), 0.25);
+  }
+  50% {
+    box-shadow:
+      0 0 0 3px rgba(var(--accent-active-rgb), 0.25),
+      0 0 30px rgba(var(--accent-active-rgb), 0.35);
+  }
+}
+
+.tour-tooltip {
+  position: fixed;
+  z-index: 2502;
+  background: var(--bg-sidebar);
+  border: 1px solid rgba(var(--accent-active-rgb), 0.4);
+  padding: 16px 20px;
+  max-width: 380px;
+  min-width: 280px;
+  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
+  animation: tour-tooltip-enter 0.25s ease-out;
+}
+
+.tour-tooltip-centered {
+  max-width: 440px;
+}
+
+@keyframes tour-tooltip-enter {
+  from {
+    opacity: 0;
+    transform: translateY(6px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+  }
+}
+
+.tour-tooltip-header {
+  font-size: 14px;
+  font-weight: 600;
+  color: var(--text-primary);
+  margin-bottom: 8px;
+}
+
+.tour-tooltip-body {
+  font-size: 12px;
+  line-height: 1.5;
+  color: var(--text-secondary);
+  margin-bottom: 16px;
+}
+
+.tour-tooltip-footer {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 8px;
+}
+
+.tour-step-counter {
+  font-size: 11px;
+  color: var(--text-muted);
+  white-space: nowrap;
+}
+
+.tour-tooltip-buttons {
+  display: flex;
+  gap: 6px;
+}
+
+.tour-btn {
+  background: rgba(255, 255, 255, 0.05);
+  border: 1px solid var(--border);
+  color: var(--text-secondary);
+  padding: 6px 14px;
+  font-size: 12px;
+  font-family: inherit;
+  border-radius: 0;
+  cursor: pointer;
+  transition: background 0.1s, color 0.1s;
+}
+
+.tour-btn:hover {
+  background: var(--bg-active);
+  color: var(--text-primary);
+}
+
+.tour-btn:disabled {
+  opacity: 0.4;
+  cursor: default;
+}
+
+.tour-btn-primary {
+  background: rgba(var(--accent-active-rgb), 0.18);
+  border-color: rgba(var(--accent-active-rgb), 0.42);
+  color: var(--text-primary);
+}
+
+.tour-btn-primary:hover {
+  background: rgba(var(--accent-active-rgb), 0.28);
+}
+
+/* Tour tooltip close button */
+.tour-tooltip-close {
+  position: absolute;
+  top: 8px;
+  right: 8px;
+  background: none;
+  border: none;
+  color: var(--text-muted);
+  cursor: pointer;
+  font-size: 14px;
+  font-family: inherit;
+  padding: 2px 6px;
+  line-height: 1;
+}
+
+.tour-tooltip-close:hover {
+  color: var(--text-secondary);
+}
+
+/* Elevated panels during tour (settings, info) — visible but non-interactive */
+.tour-elevated-panel {
+  z-index: 2504 !important;
+  position: relative;
+}
+
+.tour-elevated-panel > .settings-overlay {
+  z-index: 2504;
+  background: transparent;
+  pointer-events: none;
+}
+
+.tour-elevated-panel > .settings-overlay > .settings-panel,
