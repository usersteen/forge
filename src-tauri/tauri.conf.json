{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Forge",
  "version": "0.5.10",
  "identifier": "com.forge.terminal",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5199",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "node scripts/bump-version.cjs && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Forge",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
